# =============================================================================
# MediConnect – Shared Root .env Template
# =============================================================================
# Copy this file to the PROJECT ROOT as .env, then fill in every value.
#
#   cp "Machine Split Files/.env.template" .env
#
# All five machine IPs are required on EVERY machine.
# Service-specific secrets (API keys, credentials) stay in each service's
# own .env file under backend/<service>/.env — see notes below.
# =============================================================================


# -----------------------------------------------------------------------------
# Machine IPs
# Run `ipconfig` (Windows) or `ip addr` (Linux/Mac), find your WiFi IPv4.
# Share all five IPs with the group before starting.
# -----------------------------------------------------------------------------

MACHINE_A=192.168.X.X   # Person 1 – Kong, RabbitMQ, Redis, Frontend
MACHINE_B=192.168.X.X   # Person 2 – notification-wrapper, telegram-wrapper, twilio-wrapper
MACHINE_C=192.168.X.X   # Person 3 – patient-service, appointment-service, book-appointment, consultation-service, start-consultation
MACHINE_D=192.168.X.X   # Person 4 – doctor-service, complete-consultation, mc-service, inventory-service, amazon-s3-wrapper, openai-wrapper
MACHINE_E=192.168.X.X   # Person 5 – delivery-service, rider-service, assign-delivery, complete-delivery, payment services, tracking, distance-matrix-wrapper


# -----------------------------------------------------------------------------
# Firebase (Machine A only – Kong config + Frontend)
# Find these in your Firebase project: Project Settings → General → Your apps
# -----------------------------------------------------------------------------

FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here


# =============================================================================
# Service-specific .env files (NOT stored here)
# Each service below needs its own .env file in the listed path.
# These contain secrets that differ per service (API keys, DB URLs, etc.).
# =============================================================================
#
# Machine B:
#   backend/notification_wrapper/.env
#   backend/telegram_wrapper/.env
#   backend/twilio-wrapper/.env
#
# Machine C:
#   backend/consultation-service/.env
#   backend/start-consultation-composite/.env
#
# Machine D:
#   backend/amazon-s3-wrapper/.env
#   backend/openai-wrapper/.env
#   backend/mc-service/.env
#   backend/inventory/.env
#   backend/complete-consultation-composite/.env
#
# Machine E:
#   backend/distance-matrix-wrapper/.env   ← GOOGLE_MAPS_API_KEY goes here
#   backend/payment_wrapper/.env
# =============================================================================
