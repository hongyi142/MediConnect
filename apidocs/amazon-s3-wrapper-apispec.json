{
  "openapi": "3.0.3",
  "info": {
    "title": "Amazon S3 Wrapper",
    "description": "Wrapper service for uploading, fetching presigned URLs for, and deleting files in Amazon S3.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:5022", "description": "Local development" }
  ],
  "tags": [
    { "name": "File Storage" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["File Storage"],
        "summary": "Health check",
        "responses": { "200": { "description": "Service is healthy" } }
      }
    },
    "/UploadFile": {
      "post": {
        "tags": ["File Storage"],
        "summary": "Upload a file to S3",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["folderName", "subFolderName", "fileName", "file"],
                "properties": {
                  "folderName": { "type": "string", "example": "mediconnect" },
                  "subFolderName": { "type": "string", "example": "medication-images" },
                  "fileName": { "type": "string", "example": "medication_abc_1713000000.png" },
                  "file": { "type": "string", "description": "Base64-encoded file content" },
                  "override": { "type": "boolean", "default": false }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded, returns S3 object key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "key": { "type": "string", "description": "S3 object key for the uploaded file" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/FetchFileUrl": {
      "post": {
        "tags": ["File Storage"],
        "summary": "Get a presigned download URL",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["folderName", "subFolderName", "key"],
                "properties": {
                  "folderName": { "type": "string", "example": "mediconnect" },
                  "subFolderName": { "type": "string", "example": "medication-images" },
                  "key": { "type": "string", "description": "S3 object key returned from UploadFile" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Presigned URL returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": { "type": "string", "description": "Presigned S3 download URL" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/DeleteFile": {
      "post": {
        "tags": ["File Storage"],
        "summary": "Delete a file from S3",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["folderName", "subFolderName", "key"],
                "properties": {
                  "folderName": { "type": "string" },
                  "subFolderName": { "type": "string" },
                  "key": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
