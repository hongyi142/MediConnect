{
  "openapi": "3.0.3",
  "info": {
    "title": "Process Payment Service",
    "description": "Composite service that orchestrates payment checkout via Stripe, records payment atomically in Firestore, verifies payment, updates the OutSystems order status, and triggers delivery assignment via RabbitMQ.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:5002", "description": "Local development" }
  ],
  "tags": [
    { "name": "Payment" }
  ],
  "paths": {
    "/api/checkout": {
      "post": {
        "tags": ["Payment"],
        "summary": "Initiate payment checkout",
        "description": "Fetches order total from OutSystems, creates a Stripe checkout session via the payment wrapper, and records a pending payment entry in Firestore via the payment atomic service.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["orderID", "patientID"],
                "properties": {
                  "orderID": { "type": "string", "example": "42" },
                  "patientID": { "type": "string", "example": "patient-abc123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Checkout session created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "checkout_url": { "type": "string", "description": "Stripe-hosted checkout page URL" },
                    "session_id": { "type": "string", "description": "Stripe checkout session ID" },
                    "documentID": { "type": "string", "description": "Firestore payment record ID" }
                  }
                }
              }
            }
          },
          "400": { "description": "Missing required fields or invalid order total" },
          "404": { "description": "Order not found in OutSystems" },
          "502": { "description": "Upstream service error (Order API or Payment wrapper)" },
          "503": { "description": "Could not reach upstream service" }
        }
      }
    },
    "/api/verify": {
      "post": {
        "tags": ["Payment"],
        "summary": "Verify payment and trigger delivery",
        "description": "Verifies Stripe payment status, updates the Firestore payment ledger to 'paid', updates the OutSystems order status to 'paid', fetches patient data for delivery, and publishes a 'delivery.assign' event to RabbitMQ.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["session_id", "documentID", "orderID", "patientID"],
                "properties": {
                  "session_id": { "type": "string", "description": "Stripe checkout session ID" },
                  "documentID": { "type": "string", "description": "Firestore payment record ID from /api/checkout" },
                  "orderID": { "type": "string" },
                  "patientID": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment verified and delivery assignment triggered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Payment verified and delivery assignment triggered successfully." }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Payment is not complete",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string" },
                    "current_status": { "type": "string" }
                  }
                }
              }
            }
          },
          "404": { "description": "Patient or order not found" },
          "502": {
            "description": "Payment verified but RabbitMQ delivery handoff failed, or upstream error"
          }
        }
      }
    }
  }
}
