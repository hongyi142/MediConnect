# Internal service URLs
PATIENT_SERVICE_URL=http://patient-service:5030
DOCTOR_SERVICE_URL=http://doctor-service:5031
APPOINTMENT_SERVICE_URL=http://appointment-service:5032
NOTIFICATION_WRAPPER_URL=http://notification-wrapper:5011
OPENAI_WRAPPER_URL=http://openai-wrapper:5021
SSE_SERVICE_URL=http://notification-wrapper:5011

# RabbitMQ connection URL
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Redis — used for slot locking to prevent double-booking
REDIS_URL=redis://redis:6379/0

# Set to 1 to disable the RabbitMQ doctor-notification consumer (e.g. for testing)
DISABLE_BOOKING_RABBIT_CONSUMER=0
