# Flask
FLASK_APP=app.py
FLASK_RUN_PORT=5001
FLASK_DEBUG=0

# Stripe — obtain from https://dashboard.stripe.com/apikeys
# Use sk_test_... for test mode, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

# URLs the patient is redirected to after Stripe checkout
CLIENT_SUCCESS_URL=http://localhost:8080/patient/payment
CLIENT_CANCEL_URL=http://localhost:8080/patient/payment
